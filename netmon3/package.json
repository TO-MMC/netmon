{
  "name": "netmon",
  "version": "3.0.0",
  "description": "Windows Desktop Network Speed Monitor Widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.netmon.widget",
    "productName": "NetMon",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.png",
      "sign": null
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.0.0",
    "sql.js": "^1.10.0"
  }
}
